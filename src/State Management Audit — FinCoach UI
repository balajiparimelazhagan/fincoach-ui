    queryKey: queryKeys.monthTotals(year, month),
    queryFn: () => transactionService.getMonthTotals(year, month),
  });
}

export function useUpdateTransaction() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: ({ id, updates, scope }: { id: string; updates: any; scope?: string }) =>
      scope
        ? transactionService.bulkUpdateTransactions(id, updates, scope as any)
        : transactionService.updateTransaction(id, updates),

    onSuccess: () => {
      // Invalidate all transaction queries — any list that showed this tx needs to refresh
      queryClient.invalidateQueries({ queryKey: ['transactions'] });
    },
  });
}

export function useCreateTransaction() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: transactionService.createTransaction,
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['transactions'] });
    },
  });
}
