import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query';
import { budgetService, CustomBudgetItem } from '../../services/budgetService';
import { queryKeys } from '../../lib/queryKeys';

export function useCustomBudgetItems() {
  return useQuery({
    queryKey: queryKeys.customBudgetItems(),
    queryFn: () => budgetService.getCustomItems(),
  });
}

export function useCreateBudgetItem() {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: budgetService.createCustomItem,
    onSuccess: () => queryClient.invalidateQueries({ queryKey: queryKeys.customBudgetItems() }),
  });
}

export function useDeleteBudgetItem() {
  const queryClient = useQueryClient();
  return useMutation({
    mutationFn: (id: string) => budgetService.deleteCustomItem(id),

    // Optimistic removal from list
    onMutate: async (id) => {
      await queryClient.cancelQueries({ queryKey: queryKeys.customBudgetItems() });
      const previous = queryClient.getQueryData(queryKeys.customBudgetItems());
      queryClient.setQueryData(queryKeys.customBudgetItems(), (old: CustomBudgetItem[] | undefined) =>
        old?.filter(item => item.id !== id) ?? []
      );
      return { previous };
    },

    onError: (_err, _id, context: any) => {
      queryClient.setQueryData(queryKeys.customBudgetItems(), context.previous);
    },

    onSettled: () => queryClient.invalidateQueries({ queryKey: queryKeys.customBudgetItems() }),
  });
}
TASK 4 — Update UserContext to use TanStack Query internally
Goal: UserContext currently does its own fetch with useEffect. Replace that fetch with TanStack Query so profile/preferences data is cached and shared.

Why keep UserContext at all: Other parts of the app need profile and preferences via useUser(). That hook interface doesn't need to change — we just make the data source be TanStack Query instead of raw fetch.

Open src/context/UserContext.tsx. Change fetchUserData to read from TanStack Query cache:


import { useQuery } from '@tanstack/react-query';
import { queryKeys } from '../lib/queryKeys';

// Inside the provider, replace the useEffect + fetch with:
const { data: profileData, isLoading: profileLoading } = useQuery({
  queryKey: queryKeys.userProfile(),
  queryFn: () => userService.getUserProfile(),
  enabled: isAuthenticated, // only fetch if user is logged in
});

const { data: preferencesData, isLoading: prefsLoading } = useQuery({
  queryKey: queryKeys.userPreferences(),
  queryFn: () => userService.getUserPreferences(),
  enabled: isAuthenticated,
});
Then derive state from these queries instead of dispatching actions. The useReducer can be simplified to just auth state (isAuthenticated) since profile/preferences are now managed by TanStack Query.

